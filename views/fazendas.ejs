<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Fazendas - Nutrivida</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="pagina-fazendas">

<%- include('partials/navbar') %>

<main class="conteudo-pagina">

  <div class="titulo-pagina">
    <h1>Fazendas Urbanas</h1>
    <% if (usuario) { %>
      <a href="/fazendas/nova" class="btn-verde">+ Cadastrar Fazenda</a>
    <% } else { %>
      <p><a href="/auth/login">Faça login</a> para cadastrar uma fazenda.</p>
    <% } %>
  </div>

  <!-- Fazendas cadastradas no sistema -->
  <div class="container-problemas">
    <% if (fazendas.length === 0) { %>
      <p style="padding: 20px; color: #4a6e4a;">Nenhuma fazenda cadastrada ainda.</p>
    <% } %>

    <% fazendas.forEach(function(fazenda) { %>
      <div class="bloco-problema" id="fazenda-<%= fazenda._id %>">
        <h2><%= fazenda.nome %></h2>
        <p><strong>Localização:</strong> <%= fazenda.localizacao %></p>
        <p><strong>Tipo:</strong> <%= fazenda.tipo %></p>
        <% if (fazenda.descricao) { %>
          <p><%= fazenda.descricao %></p>
        <% } %>
        <% if (usuario) { %>
          <button class="btn-perigo" onclick="deletarFazenda('<%= fazenda._id %>')">Remover</button>
        <% } %>
      </div>
    <% }) %>
  </div>

  <hr>

  <!-- Seção: Fazendas que já atendemos -->
  <div class="secao-atendidas">
    <h2>Fazendas que já Atendemos</h2>
    <p class="subtexto-atendidas">Conheça alguns dos nossos clientes e os resultados conquistados com as nossas soluções em Barueri e região.</p>

    <div class="grid-fazendas-clientes">

      <div class="card-fazenda-cliente">
        <div class="card-foto">
          <img src="https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=600&h=380&fit=crop" alt="Verde Vivo Urban Farm">
          <span class="card-badge">Hidroponia</span>
        </div>
        <div class="card-info">
          <h3>Verde Vivo Urban Farm</h3>
          <p class="card-local">📍 Alphaville, Barueri - SP</p>
          <p class="card-desc">Implantamos sistema hidropônico vertical com sensores de pH e temperatura. Produção de alface e manjericão aumentou 3× em 4 meses.</p>
          <div class="card-tags">
            <span>Sensores IoT</span>
            <span>Automação</span>
            <span>Consultoria</span>
          </div>
        </div>
      </div>

      <div class="card-fazenda-cliente">
        <div class="card-foto">
          <img src="https://images.unsplash.com/photo-1530836369250-ef72a3f5cda8?w=600&h=380&fit=crop" alt="Horta do Futuro">
          <span class="card-badge">Aeroponia</span>
        </div>
        <div class="card-info">
          <h3>Horta do Futuro</h3>
          <p class="card-local">📍 Jardim Silveira, Barueri - SP</p>
          <p class="card-desc">Estrutura aeropônica de alta densidade instalada em 80m². Redução de 85% no consumo de água e cultivo de 12 variedades de vegetais.</p>
          <div class="card-tags">
            <span>Aeroponia</span>
            <span>Eficiência Hídrica</span>
            <span>Treinamento</span>
          </div>
        </div>
      </div>

      <div class="card-fazenda-cliente">
        <div class="card-foto">
          <img src="https://images.unsplash.com/photo-1464226184884-fa280b87c399?w=600&h=380&fit=crop" alt="Raízes Urbanas">
          <span class="card-badge">Cultivo Vertical</span>
        </div>
        <div class="card-info">
          <h3>Raízes Urbanas</h3>
          <p class="card-local">📍 Centro, Barueri - SP</p>
          <p class="card-desc">Projeto de cultivo vertical em espaço de 40m² com iluminação LED inteligente. Produção contínua o ano todo, sem depender do clima.</p>
          <div class="card-tags">
            <span>LED Inteligente</span>
            <span>Cultivo Vertical</span>
            <span>Monitoramento</span>
          </div>
        </div>
      </div>

      <div class="card-fazenda-cliente">
        <div class="card-foto">
          <img src="https://images.unsplash.com/photo-1586771107445-d3ca888129ff?w=600&h=380&fit=crop" alt="Fazenda Colibri">
          <span class="card-badge">Orgânico</span>
        </div>
        <div class="card-info">
          <h3>Fazenda Colibri</h3>
          <p class="card-local">📍 Engenho Novo, Barueri - SP</p>
          <p class="card-desc">Horta orgânica de 200m² com compostagem integrada e captação de água da chuva. Certificação orgânica obtida em 6 meses com nosso apoio.</p>
          <div class="card-tags">
            <span>Orgânico</span>
            <span>Compostagem</span>
            <span>Sustentabilidade</span>
          </div>
        </div>
      </div>

      <div class="card-fazenda-cliente">
        <div class="card-foto">
          <img src="https://images.unsplash.com/photo-1591857177580-dc82b9ac4e1e?w=600&h=380&fit=crop" alt="BioSprout">
          <span class="card-badge">Microverdes</span>
        </div>
        <div class="card-info">
          <h3>BioSprout</h3>
          <p class="card-local">📍 Alphaville Industrial, Barueri - SP</p>
          <p class="card-desc">Especialização no cultivo de microverdes e brotos. Plataforma de monitoramento instalada controla umidade e luminosidade 24h por dia.</p>
          <div class="card-tags">
            <span>Microverdes</span>
            <span>Plataforma Online</span>
            <span>Alertas em Tempo Real</span>
          </div>
        </div>
      </div>

      <div class="card-fazenda-cliente">
        <div class="card-foto">
          <img src="https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=600&h=380&fit=crop" alt="Estufa Viva">
          <span class="card-badge">Estufa Climatizada</span>
        </div>
        <div class="card-info">
          <h3>Estufa Viva</h3>
          <p class="card-local">📍 Novo Osasco, Barueri - SP</p>
          <p class="card-desc">Estufa de 300m² com controle climático automatizado. Sistema integrado de irrigação, ventilação e nutrição mineral gerenciado pela plataforma Nutrivida.</p>
          <div class="card-tags">
            <span>Estufa</span>
            <span>Clima Controlado</span>
            <span>IoT Avançado</span>
          </div>
        </div>
      </div>

    </div>
  </div>

</main>

<%- include('partials/footer') %>

<script>
  async function deletarFazenda(id) {
    const confirma = confirm('Deseja remover esta fazenda?');
    if (!confirma) return;

    try {
      const res = await fetch('/fazendas/api/' + id, { method: 'DELETE' });
      const dados = await res.json();

      if (res.ok) {
        const bloco = document.getElementById('fazenda-' + id);
        if (bloco) bloco.remove();
        alert(dados.sucesso);
      } else {
        alert(dados.erro);
      }
    } catch (err) {
      alert('Erro ao remover fazenda.');
    }
  }
</script>

</body>
</html>
